{
  "manifest_version": 3,
  "name": "VTP Tool All-in-One",
  "version": "3.1",
  "description": "Tích hợp Auto Sửa Giờ, Auto Quét Kiểm Tồn và Ghi Đơn Hàng ViettelPost",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "*://*.viettelpost.vn/*",
    "*://*.viettelpost.com.vn/*",
    "https://evtp2.viettelpost.vn/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://evtp2.viettelpost.vn/*"],
      "js": ["src/modules/ghidon/ghidon_content.js"],
      "css": ["src/modules/ghidon/ghidon_content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "assets/icons/icon16.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "VTP Tool – Mở bảng điều khiển"
  },
  "side_panel": {
    "default_path": "src/ui/sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}